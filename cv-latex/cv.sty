% cv.sty — Polished Academic CV Style
% Clean layout with right-aligned dates, structured entries, and clear hierarchy.

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{cv}

% ── Encoding & Fonts ──────────────────────────────────────
\RequirePackage[T1]{fontenc}
\RequirePackage[utf8]{inputenc}
\RequirePackage{sourceserif}
\RequirePackage{sourcecodepro}
\RequirePackage{microtype}

% ── Page Geometry ─────────────────────────────────────────
\RequirePackage[
  letterpaper,
  top=0.7in,
  bottom=0.9in,
  left=1.0in,
  right=1.0in,
  footskip=0.5in
]{geometry}

% ── Spacing ───────────────────────────────────────────────
\RequirePackage{setspace}
\setstretch{1.08}
\RequirePackage{enumitem}

% ── Colors ────────────────────────────────────────────────
\RequirePackage{xcolor}
\definecolor{heading}{HTML}{333333}
\definecolor{accent}{HTML}{96710E}
\definecolor{subtext}{HTML}{666666}
\definecolor{light}{HTML}{999999}
\definecolor{rule}{HTML}{CCCCCC}

% ── Hyperlinks ────────────────────────────────────────────
\RequirePackage[
  colorlinks=true,
  linkcolor=accent,
  urlcolor=accent,
  citecolor=accent,
  pdfborder={0 0 0}
]{hyperref}
\urlstyle{tt}

% ── Headers / Footers ────────────────────────────────────
\RequirePackage{fancyhdr}
\RequirePackage{lastpage}
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}

% Footer helper
\newcommand{\grayfoot}[2]{%
  \fancyfoot[#1]{\footnotesize\color{subtext}#2}%
}

% ── Tabular helpers ──────────────────────────────────────
\RequirePackage{tabularx}

% ── Title: \name{} ───────────────────────────────────────
\newcommand{\name}[1]{%
  \begin{center}
    {\fontsize{22}{26}\selectfont\scshape\color{heading} #1}\\[0.4em]
    {\color{accent}\rule{2cm}{0.8pt}}
  \end{center}
  \vspace{0.1em}
}

% ── Contact row ──────────────────────────────────────────
\newcommand{\contact}[1]{%
  \begin{center}
    \small\color{subtext}#1
  \end{center}
  \vspace{0.2em}
}

% ── Section blocks: \block{} ─────────────────────────────
\newcommand{\block}[1]{%
  \vspace{1.0em}
  {\noindent\fontsize{11}{13}\selectfont\scshape\color{accent}#1}%
  \vspace{0.2em}
  \par\noindent{\color{rule}\hrule height 0.5pt}
  \vspace{0.5em}
}

% ── Structured entry ─────────────────────────────────────
% \entry{Institution}{Role}{Date}{Description}
\newcommand{\entry}[4]{%
  \noindent
  \begin{tabularx}{\textwidth}{@{}X r@{}}
    \textbf{#1} & {\small\color{subtext}#3}
  \end{tabularx}\\[-0.2em]
  {\color{subtext}\textit{#2}}\\[0.15em]
  {\small #4}
  \vspace{0.55em}\par
}

% ── Short entry (no description) ─────────────────────────
% \shortentry{Title}{Detail}{Date}
\newcommand{\shortentry}[3]{%
  \noindent
  \begin{tabularx}{\textwidth}{@{}X r@{}}
    \textbf{#1} & {\small\color{subtext}#3}
  \end{tabularx}\\[-0.2em]
  {\small #2}
  \vspace{0.45em}\par
}

% ── One-line entry ───────────────────────────────────────
% \lineentry{Content}{Date}
\newcommand{\lineentry}[2]{%
  \noindent
  \begin{tabularx}{\textwidth}{@{}X r@{}}
    #1 & {\small\color{subtext}#2}
  \end{tabularx}
  \vspace{0.2em}\par
}

% ── Inline separator ─────────────────────────────────────
\newcommand{\sep}{%
  \hspace{0.35em}{\color{light}\textbullet}\hspace{0.35em}%
}

% ── Publication entry ────────────────────────────────────
% \pub{Title+Link}{Authors}{Venue}{Year}
\newcommand{\pub}[4]{%
  \item #1\\[0.1em]
  {\small #2}\\[0.1em]
  {\small\color{subtext}\textit{#3}\hfill #4}
}

% ── Entry with title only (for bullet-point entries) ─────
% \entrytitle{Institution}{Role}{Date}
\newcommand{\entrytitle}[3]{%
  \noindent
  \begin{tabularx}{\textwidth}{@{}X r@{}}
    \textbf{#1} & {\small\color{subtext}#3}
  \end{tabularx}\\[-0.2em]
  {\color{subtext}\textit{#2}}
  \vspace{0.1em}\par
}

% ── Bullet list for within entries ───────────────────────
\newlist{bullets}{itemize}{1}
\setlist[bullets]{
  leftmargin=1.5em,
  labelsep=0.5em,
  itemsep=0.15em,
  parsep=0pt,
  topsep=0.1em,
  partopsep=0pt,
  after=\vspace{0.45em},
  label={\color{light}\textbullet}
}

% ── List formatting ───────────────────────────────────────
\setlist[itemize]{
  leftmargin=0em,
  labelsep=0em,
  itemsep=0.3em,
  parsep=0pt,
  label={}
}

% Reverse-numbered list for publications
\RequirePackage{etaremune}

% ── Misc ──────────────────────────────────────────────────
\setlength{\parindent}{0pt}
\RequirePackage{parskip}
